<h1 class="text-3xl font-bold mb-2"><%= @project.name %></h1>
<p class="text-gray-700 mb-6">
  This page shows all tasks associated with this project.  
  Use it to add new tasks, update progress, or remove completed items.
</p>

<p class="mb-10 text-gray-600"><%= @project.description %></p>


<!-- ========================= -->
<!--   TASK LIST SECTION       -->
<!-- ========================= -->
<div class="mb-12">
  <h2 class="text-2xl font-semibold mb-2">Tasks for this Project</h2>
  <p class="text-gray-600 mb-4">
    Below is a list of tasks currently assigned to this project.  
    Update or delete tasks as work progresses.
  </p>

  <div class="bg-white border rounded p-4 shadow-sm">
    <%= turbo_frame_tag "tasks" do %>
      <% if @tasks.any? %>
        <%= render @tasks %>
      <% else %>
        <p class="text-gray-500 italic">No tasks yet. Add one below.</p>
      <% end %>
    <% end %>
  </div>
</div>


<!-- ========================= -->
<!--   ADD NEW TASK SECTION    -->
<!-- ========================= -->
<div class="pt-8 border-t">
  <h3 class="text-2xl font-semibold mb-2">Add a New Task</h3>
  <p class="text-gray-600 mb-4">
    Enter a task name and choose a status to track progress.  
    Tasks update instantly using Turbo Streams.
  </p>

  <div class="bg-gray-50 border rounded p-4 shadow-inner">
    <%= render "tasks/form", task: @task, project: @project %>
  </div>
</div>


<!-- ========================= -->
<!--   NAVIGATION LINKS        -->
<!-- ========================= -->
<div class="mt-10 space-x-4">
  <%= link_to "Edit Project", edit_project_path(@project), class: "text-blue-600" %>
  <%= link_to "Back to Projects", projects_path, class: "text-gray-600" %>
</div>


