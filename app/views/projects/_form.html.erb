<%= form_with(model: project, class: "space-y-4") do |f| %>
  <div>
    <%= f.label :name, class: "block font-semibold" %>
    <%= f.text_field :name, class: "border p-2 w-full rounded" %>
  </div>

  <div>
    <%= f.label :description, class: "block font-semibold" %>
    <%= f.text_area :description, rows: 4, class: "border p-2 w-full rounded" %>
  </div>

  <%= f.submit "Save Project", class: "bg-blue-600 text-white px-4 py-2 rounded" %>
<% end %>
