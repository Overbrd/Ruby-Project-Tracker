<div id="<%= dom_id(task) %>" class="p-3 bg-white border rounded flex justify-between items-center shadow-sm">
  <div>
    <strong class="text-lg"><%= task.name %></strong>
    <span class="ml-2 text-gray-500">Status: <%= task.status.humanize %></span>
  </div>

  <div class="space-x-3">
    <%= link_to "Edit",
    edit_project_task_path(task.project, task),
    data: { turbo: false },
    class: "text-blue-600" %>

    <%= link_to "Delete",
        project_task_path(task.project, task),
        data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
        class: "text-red-600" %>
  </div>
</div>
